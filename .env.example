# Database
DATABASE_URL="postgresql://revenew_user:dev_password@localhost:5432/revenew_os"
DATABASE_SHADOW_URL="postgresql://revenew_user:dev_password@localhost:5432/revenew_os_shadow"

# API Server
API_PORT=3001
API_HOST=localhost
NODE_ENV=development

# Web Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Revenew OS

# Agents Service
AGENTS_PORT=8000
AGENTS_HOST=localhost

# JWT & Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION=7d

# Redis (caching/queues)
# Use REDIS_URL OR the individual REDIS_HOST + REDIS_PORT pair — not both.
# The API will parse REDIS_URL automatically if the individual keys are absent.
REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# Logging
LOG_LEVEL=info

# AI Copilot (Growth Advisor)
COPILOT_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo
# Alternative: Use Anthropic instead
# COPILOT_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-opus-4-1
