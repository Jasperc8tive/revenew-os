{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Web (Next.js)",
      "cwd": "apps/web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "API (NestJS)",
      "cwd": "apps/api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "Agents (FastAPI)",
      "cwd": "apps/agents",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "autoPort": false
    }
  ]
}
